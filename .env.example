# Twilio (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# API Key SID + Secret from Console → Account → API keys & tokens
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret

# Auth Token (Console homepage) — used to verify Conversations webhooks (recommended in production)
# TWILIO_AUTH_TOKEN=your_auth_token

# Conversations: Console → Develop → Messaging → Services → Conversations
TWILIO_CONVERSATIONS_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# In that service → Webhooks → Post-Event URL: https://YOUR-API/api/webhooks/twilio/conversations
# Enable: onConversationAdded and onMessageAdded (onMessageAdded fixes threads that existed before the webhook).
# Zapier / Messages API → Status callback URL: https://YOUR-API/api/webhooks/twilio/programmable-messaging (see README).

# Your Twilio SMS-capable number (E.164, e.g. +61412345678)
TWILIO_PHONE_NUMBER=+61412345678
# Optional: comma-separated extra "From" numbers (E.164) for your sends (Messaging Service pool, etc.)
# TWILIO_SMS_FROM_ALIASES=+61400111222,+61400333444
# Bulk SMS log sync: outbound mirror can resend SMS — off by default. Inbound-only sync is safe.
# SMS_LOG_SYNC_OUTBOUND_MIRROR=true

# Fixed Twilio chat identity for this inbox (browser user). Must match Twilio rules: letters, numbers, _, -
TWILIO_CONVERSATIONS_IDENTITY=pbsg-inbox

# Auth: bcrypt hash of the app password (never store plaintext here)
# Generate: cd backend && npm run hash-password
APP_PASSWORD_HASH=$2b$12$........................................

# Sign session JWTs (use a long random string, 32+ characters)
SESSION_JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Session lifetime in seconds (default 604800 = 7 days)
# SESSION_MAX_AGE_SECONDS=604800

PORT=3001

# Optional: comma-separated allowed origins (default: all origins in dev)
# CORS_ORIGIN=http://localhost:5173
